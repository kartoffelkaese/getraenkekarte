# Datenbank-Konfiguration
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# Server-Konfiguration
PORT=3000
NODE_ENV=development

# Admin-Zugangsdaten
ADMIN_USER=admin
ADMIN_PASSWORD=secure_password_here

# Entwicklung (npm run dev) — kein Reverse-Proxy
TRUST_PROXY=false
# Optional für npm run ext / LAN-Tests:
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.126:3000

# Produktion — hinter Reverse-Proxy
# NODE_ENV=production
# TRUST_PROXY=true
# ALLOWED_ORIGINS=https://karte.example.de
