# Datenbank-Konfiguration
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# Server-Konfiguration
PORT=3000
NODE_ENV=development

# Admin-Zugangsdaten
ADMIN_USER=admin
ADMIN_PASSWORD=secure_password_here

# --- Entwicklung (npm run dev), kein Reverse-Proxy ---
TRUST_PROXY=false
# Optional für npm run ext / LAN (kommagetrennt):
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.126:3000

# --- Produktion (hinter Reverse-Proxy) ---
# NODE_ENV=production
# TRUST_PROXY=true   (oder weglassen: in production standardmäßig true)
# Explizite Origin-Liste für API/CORS/Socket.IO (empfohlen):
# ALLOWED_ORIGINS=https://gkarte.example.de
# Oder eine kanonische URL (wird zur Allowlist hinzugefügt):
# PUBLIC_ORIGIN=https://gkarte.example.de
#
# CSP (Helmet): In production erlauben wir jsDelivr (Bootstrap), gstatic/Firestore u. a.;
# weitere CDN-Domains → src/config/security.js (getProductionContentSecurityPolicy).
#
# Ohne ALLOWED_ORIGINS/PUBLIC_ORIGIN erlaubt die App weiterhin denselben Host wie im
# Host- / X-Forwarded-Host-Header (Same-Site). Der Proxy sollte setzen:
#   Host, X-Forwarded-Proto (https), X-Forwarded-For
#
# nginx — Socket.IO / WebSockets (Auszug):
#   location /socket.io/ {
#     proxy_http_version 1.1;
#     proxy_set_header Upgrade $http_upgrade;
#     proxy_set_header Connection "upgrade";
#     proxy_set_header Host $host;
#     proxy_set_header X-Forwarded-Proto $scheme;
#     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#     proxy_buffering off;
#     proxy_read_timeout 86400;
#     proxy_pass http://127.0.0.1:3000;
#   }
