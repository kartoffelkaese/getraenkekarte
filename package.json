{
  "name": "getraenkekarte",
  "version": "4.2.3",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.16.0",
    "npm": ">=11.4.2"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "ext": "nodemon src/index.js --host 192.168.1.126 -p 3000",
    "lint": "eslint src scripts tests public/js",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.js\" \"public/js/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "test": "node --test tests/**/*.test.js",
    "build:admin": "node scripts/build-admin.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Getränkekarte mit Echtzeit-Updates",
  "dependencies": {
    "basic-auth": "^2.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "esbuild@0.28.1": true
  }
}
